page {
  background: linear-gradient(180deg, #87CEEB 0%, #E0F7FA 50%, #98FB98 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6347;
  text-align: center;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
  margin-bottom: 30rpx;
}

.btn-primary {
  background: linear-gradient(180deg, #FFD700 0%, #FFA500 100%);
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  border: 4rpx solid #FF8C00;
  padding: 20rpx 40rpx;
  text-align: center;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(255, 165, 0, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: linear-gradient(180deg, #00CED1 0%, #20B2AA 100%);
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  border: 4rpx solid #008B8B;
  padding: 20rpx 40rpx;
  text-align: center;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(0, 178, 170, 0.3);
}

.btn-secondary:active {
  transform: scale(0.98);
}

.btn-pink {
  background: linear-gradient(180deg, #FF69B4 0%, #FF1493 100%);
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  border: 4rpx solid #C71585;
  padding: 20rpx 40rpx;
  text-align: center;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(255, 20, 147, 0.3);
}

.btn-pink:active {
  transform: scale(0.98);
}

.card {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 40rpx;
}

.mb-20 {
  margin-bottom: 40rpx;
}

.flex {
  display: flex;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-center {
  justify-content: center;
}

.align-center {
  align-items: center;
}

.gap-20 {
  gap: 40rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}