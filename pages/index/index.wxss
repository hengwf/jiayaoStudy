.container {
  padding: 40rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.main-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF6347;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
  display: block;
  margin-bottom: 20rpx;
}

.sub-title {
  font-size: 28rpx;
  color: #5D4037;
}

.character-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.character {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(180deg, #FFE082 0%, #FFC107 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 25rpx rgba(255, 193, 7, 0.4);
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.character-emoji {
  font-size: 100rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.menu-item {
  height: 200rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 4rpx solid;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
  transition: transform 0.2s;
}

.menu-item:active {
  transform: scale(0.96);
}

.menu-item.game {
  background: linear-gradient(180deg, #FFD700 0%, #FFA500 100%);
  border-color: #FF8C00;
  grid-column: span 1;
}

.menu-item.learning {
  background: linear-gradient(180deg, #00CED1 0%, #20B2AA 100%);
  border-color: #008B8B;
  grid-column: span 1;
}

.menu-item.story {
  background: linear-gradient(180deg, #FF69B4 0%, #FF1493 100%);
  border-color: #C71585;
  grid-column: span 2;
}

.menu-icon {
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.menu-text {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.score-section {
  text-align: center;
}

.score-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}
