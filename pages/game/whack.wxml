<view class="container">
  <view class="game-header">
    <view class="back-btn" bindtap="goBack">
      <text>← 返回</text>
    </view>
    <text class="game-title">🔨 打地鼠</text>
    <view class="level-info">
      <text>第 {{currentLevel}} 关</text>
    </view>
  </view>
  
  <view class="game-stats">
    <view class="stat-item">
      <text class="stat-label">🎯 得分:</text>
      <text class="stat-value">{{score}} / {{targetScore}}</text>
    </view>
    <view class="stat-item">
      <text class="stat-label">⏱️ 时间:</text>
      <text class="stat-value">{{timeLeft}}秒</text>
    </view>
  </view>
  
  <view class="whack-grid">
    <view 
      wx:for="{{holes}}" 
      wx:key="index"
      class="hole"
      bindtap="whackMole"
      data-index="{{index}}"
    >
      <view class="mole" style="opacity: {{item.show ? 1 : 0}};">
        <text class="mole-emoji">{{item.show ? '🐹' : ''}}</text>
      </view>
      <view class="hit-effect" style="opacity: {{item.hit ? 1 : 0}};">💥</view>
    </view>
  </view>
  
  <view class="game-controls">
    <view class="control-btn" bindtap="startGame">
      <text>{{gameStarted ? '⏸ 暂停' : '▶ 开始'}}</text>
    </view>
  </view>
  
  <view class="level-select">
    <text class="select-title">选择关卡:</text>
    <view class="level-grid">
      <view 
        wx:for="{{levels}}" 
        wx:key="index"
        class="level-item"
        bindtap="selectLevel"
        data-level="{{index + 1}}"
        style="background-color: {{index < unlockedLevel ? '#4CAF50' : '#BDBDBD'}};"
      >
        <text>{{index + 1}}</text>
      </view>
    </view>
  </view>
</view>
